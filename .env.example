# Azure DevOps Configuration
AZURE_ORG="aauti"
AZURE_PROJECT="HealthCare"
AZURE_PAT="your-person-access-token-here"

# Identity Configuration
AZURE_ASSIGNEE="Mihir Patwa" # The name of the developer to triage tickets for
AGENT_NAME="Aria"           # The name of your AI agent

# Engine selection
# ARIA_AGENT_MODE="auto"     # Options: auto, local, agnostic, claude, gemini, codex, auggie, custom
AI_ENGINE="auto"
AI_BIN=""
AI_CLI_STYLE="auto"         # Options: auto, claude, single_prompt, stdin, agnostic, local
AI_PROMPT_FLAG="-p"
AI_EXTRA_ARGS=""
AI_IDE_NAME=""

# Delivery automation
ARIA_ENABLE_POST_ACTIONS="true"
ARIA_APPROVE_SENSITIVE_ACTIONS="false" # false | true | commit,push,azure
ARIA_GIT_REMOTE="origin"
ARIA_PUSH_AFTER_COMMIT="true"
ARIA_AZURE_COMMENT_ON_COMPLETE="true"
AZURE_TRANSITION_STATE=""

# QA Automation Configuration
QA_TEST_EMAIL="erik@mailinator.com"           # Test account email for automated testing
QA_TEST_PASSWORD="Robert@123"                 # Test account password for automated testing
QA_DEV_SERVER_URL="http://localhost:5173"     # Local development server URL for testing
QA_ENABLE_CHROME_MCP="true"                   # Enable Chrome MCP for automated browser testing
