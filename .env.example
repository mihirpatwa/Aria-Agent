# ═══════════════════════════════════════════════════════════════════════════════
# AZURE DEVOPS CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# Configure your Azure DevOps organization and project details
# Find your org name: https://dev.azure.com/{your-org}/
# Find your project name: Navigate to your project in Azure DevOps

AZURE_ORG="your-azure-org"                      # Your Azure DevOps organization name (e.g., "mycompany" from https://dev.azure.com/mycompany/)
AZURE_PROJECT="your-project-name"               # Your Azure DevOps project name (e.g., "E-Commerce", "InternalTools")
AZURE_PAT="your-person-access-token-here"       # Generate at: https://dev.azure.com/{your-org}/_usersSettings/tokens

# ═══════════════════════════════════════════════════════════════════════════════
# IDENTITY CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# Configure which developer the agent will triage work items for
# Use your exact display name as it appears in Azure DevOps

AZURE_ASSIGNEE="your-name-or-assignee"          # The developer name to assign tickets to (must match Azure DevOps display name exactly)
AGENT_NAME="Aria"                               # The name of your AI agent (customize as desired)

# ═══════════════════════════════════════════════════════════════════════════════
# AI ENGINE SELECTION
# ═══════════════════════════════════════════════════════════════════════════════
# Configure which AI engine the agent should use
# Options: auto (automatically detect), claude, gemini, codex, local, agnostic, custom

AI_ENGINE="auto"                                # AI engine to use: "auto" for automatic detection
AI_BIN=""                                       # Custom AI binary path (only if AI_ENGINE="custom")
AI_CLI_STYLE="auto"                             # CLI interaction style: "auto", "claude", "single_prompt", "stdin", "agnostic", "local"
AI_PROMPT_FLAG="-p"                             # Flag for passing prompts to your AI CLI
AI_EXTRA_ARGS=""                                # Additional arguments to pass to the AI CLI
AI_IDE_NAME=""                                  # IDE name for context (optional, for logging/debugging)

# ═══════════════════════════════════════════════════════════════════════════════
# DELIVERY AUTOMATION
# ═══════════════════════════════════════════════════════════════════════════════
# Configure automated Git and Azure DevOps actions after completing work

ARIA_ENABLE_POST_ACTIONS="true"                 # Enable post-completion actions (commit, push, comment)
ARIA_APPROVE_SENSITIVE_ACTIONS="false"          # Require approval for sensitive actions: "false", "true", or comma-separated "commit,push,azure"
ARIA_GIT_REMOTE="origin"                        # Git remote name for pushing changes
ARIA_PUSH_AFTER_COMMIT="true"                   # Automatically push to remote after committing
ARIA_AZURE_COMMENT_ON_COMPLETE="true"           # Post completion comment on Azure DevOps work item
AZURE_TRANSITION_STATE=""                       # Optional: Azure DevOps state transition on complete (e.g., "Closed", "Resolved")

# ═══════════════════════════════════════════════════════════════════════════════
# QA AUTOMATION CONFIGURATION (OPTIONAL)
# ═══════════════════════════════════════════════════════════════════════════════
# Configure automated QA testing with Chrome MCP
# Only fill these in if you want to enable automated browser testing

QA_TEST_EMAIL="your-test-email@example.com"     # Test account email for automated QA testing
QA_TEST_PASSWORD="your-test-password"           # Test account password for automated QA testing
QA_DEV_SERVER_URL="http://localhost:3000"       # Local development server URL for testing (e.g., "http://localhost:3000", "http://localhost:5173")
QA_ENABLE_CHROME_MCP="true"                     # Enable Chrome MCP for automated browser testing (requires Chrome MCP installation)

# ═══════════════════════════════════════════════════════════════════════════════
# CHROME MCP CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# Chrome MCP for automated browser testing
# Chrome MCP is automatically installed via npx during QA if not available
# Universal command: npx -y chrome-devtools-mcp@latest
# Compatible with: Claude, Cursor, Windsurf, Auggie, Kiro, Qoder, and more

CHROME_MCP_ENABLED="true"                       # Chrome MCP master switch (true/false)
CHROME_MCP_AUTO_INSTALL="true"                  # Automatically install Chrome MCP if not available (true/false)

# ═══════════════════════════════════════════════════════════════════════════════
# SETUP INSTRUCTIONS
# ═══════════════════════════════════════════════════════════════════════════════
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your Azure DevOps configuration (ORG, PROJECT, PAT)
# 3. Set your assignee name (must match Azure DevOps exactly)
# 4. Optionally configure QA testing if you want automated browser testing
# 5. See UNIVERSAL-SETUP.md for detailed step-by-step instructions
# ═══════════════════════════════════════════════════════════════════════════════
